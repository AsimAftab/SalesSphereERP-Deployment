# Production env for the SalesSphere ERP backend.
#
# Copy this file to `.env` on the droplet and fill in real values, then
# `chmod 600 .env`. NEVER commit the `.env` file — it contains secrets.
# The compose file's `env_file: .env` loads everything in here into the
# `app` container at startup.
#
# Most keys mirror the backend repo's `.env.example` — see the comments
# there for what each one does. The notes below only call out
# production-specific deviations.

# --- Image tag ---
# Set by CI via the SSH `envs:` mechanism — what's here is just the local
# default for manual `docker compose` runs. CI pushes `sha-<short-sha>`
# tags; production deploys reference those for immutable rollbacks.
IMAGE_TAG=latest

# --- Server ---
NODE_ENV=production
PORT=3000
APP_URL=https://api.salessphere.com
CORS_ORIGIN=https://app.salessphere.com

# --- Database (DO Managed Postgres in Bangalore) ---
# Get the URL from the DO dashboard → Databases → "Connection details" →
# "Connection string". Use the POOLED connection string for the app.
DATABASE_URL=postgresql://USER:PASSWORD@private-db-prod-xxxx.db.ondigitalocean.com:25061/defaultdb?sslmode=require

# --- Redis ---
# Internal docker network — DON'T change this. The compose file overrides
# this value for the app container; left here for clarity / dev parity.
REDIS_URL=redis://redis:6379

# --- Auth ---
# Generate fresh 32+ char random strings for prod. NEVER reuse dev values.
#   openssl rand -base64 48     # gives ~64 chars
JWT_SECRET=<generate-a-fresh-32+-char-random-string>
JWT_REFRESH_SECRET=<a-different-32+-char-random-string>
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CSRF_SECRET=<another-different-32+-char-random-string>
COOKIE_DOMAIN=api.salessphere.com

# --- File storage (Cloudinary) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=salessphere-prod

# --- Email ---
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=
SMTP_SECURE=true
SMTP_FROM=no-reply@salessphere.com
SMTP_FROM_NAME=SalesSphere
PASSWORD_RESET_URL=https://app.salessphere.com/auth/reset-password
EMAIL_VERIFICATION_URL=https://app.salessphere.com/auth/verify-email
RESEND_API_KEY=

# --- Platform super-admin ---
# Bootstrap the first SUPER_ADMIN account. The seed script (run once
# manually after first deploy) creates it. Change SUPERADMIN_PASSWORD via
# /auth/forgot-password immediately after the first login.
SUPERADMIN_EMAIL=admin@salessphere.com
SUPERADMIN_PASSWORD=<generate-a-strong-password-and-rotate-immediately>

# --- IRD (Nepal Inland Revenue) ---
IRD_ENABLED=false
IRD_API_BASE=
IRD_TAXPAYER_PAN=
IRD_SOFTWARE_ID=

# --- Logging ---
LOG_LEVEL=info
